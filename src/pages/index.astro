---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 取最新6篇文章
const recentPosts = posts.slice(0, 6);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		
		<!-- Hero Section -->
		<section class="hero">
			<div class="hero-content">
				<h1>记录学习与创造的<span class="text-gradient">每一步</span></h1>
				<p>AI · OpenClaw · Astro · 网站开发</p>
				<div style="margin-top: 2rem;">
					<a href="/blog/" class="btn btn-secondary">浏览文章</a>
					<a href="/about/" class="btn btn-outline" style="margin-left: 1rem;">关于我</a>
				</div>
			</div>
		</section>
		
		<main class="container">
			<!-- 最新文章 -->
			<section class="section">
				<div class="section-title">
					<h2>最新文章</h2>
					<p>探索技术、分享经验、记录成长</p>
				</div>
				
				<div class="card-grid">
					{
						recentPosts.map((post) => (
							<article class="card post-card">
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<img
											class="post-card-image"
											src={post.data.heroImage}
											alt={post.data.title}
											loading="lazy"
										/>
									)}
								</a>
								<div class="post-card-meta">
									<FormattedDate date={post.data.pubDate} />
								</div>
								<h3 class="post-card-title">
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h3>
								<p class="post-card-description">{post.data.description}</p>
								{post.data.tags && (
									<div class="post-card-tags">
										{post.data.tags.slice(0, 3).map((tag) => (
											<a href={`/tags/${tag}/`} class="tag">{tag}</a>
										))}
									</div>
								)}
							</article>
						))
					}
				</div>
				
				<div style="text-align: center; margin-top: 3rem;">
					<a href="/blog/" class="btn btn-primary">查看全部文章</a>
				</div>
			</section>
		</main>
		
		<Footer />
	</body>
</html>
