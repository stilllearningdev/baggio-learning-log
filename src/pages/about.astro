---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com/stilllearningdev/baggio-learning-log' },
  { name: 'Blog', url: '/blog' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`About - ${SITE_TITLE}`} description="About Baggio Learning Log" />
  </head>
  <body>
    <Header />
    <main class="page-enter">
      <section class="about-page">
        <div class="about-avatar">
          <img src="https://picsum.photos/seed/baggio-avatar/200/200" alt="Avatar" />
        </div>
        <h1 class="about-name">Baggio</h1>
        <p class="about-bio">创业者 · 内容创作者 · 全栈学习者</p>
        <p class="about-text">
          热爱折腾 AI 和 Web 技术，用 OpenClaw 搭建个人效率系统，用 Astro 写博客，
          用代码记录学习路上的每一个坑和每一点收获。
        </p>
        <div class="about-interests">
          <span class="interest-tag">🤖 AI / OpenClaw</span>
          <span class="interest-tag">🌐 Astro / Web Dev</span>
          <span class="interest-tag">📝 Content Creation</span>
          <span class="interest-tag">💡 Open Source</span>
        </div>
        <div class="about-links">
          {socialLinks.map(link => (
            <a href={link.url} class="about-link" target="_blank" rel="noopener">
              {link.name}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .about-page {
    max-width: 560px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .about-avatar {
    margin-bottom: 1.5rem;
  }

  .about-avatar img {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    margin: 0 auto;
    border: 2px solid var(--border);
    object-fit: cover;
  }

  .about-name {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.25rem;
  }

  .about-bio {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }

  .about-text {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .about-interests {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .interest-tag {
    display: inline-block;
    font-size: 0.8125rem;
    padding: 0.35rem 0.85rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-dim);
    border-radius: 100px;
    color: var(--text-secondary);
  }

  .about-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .about-link:hover {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .about-page {
      padding: 2.5rem 1rem;
    }
  }
</style>
